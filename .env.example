# Copy to .env.local and fill in real values. Never commit the filled-in file.

# --- Postgres / Supabase --------------------------------------------------
# Runtime connection used by the app (least-privilege `app_user` role, RLS
# always enforced). Create this role via db/migrations/0001_init.sql, then
# set its password out-of-band (never in this file's committed template):
#   ALTER ROLE app_user WITH PASSWORD '...';
DATABASE_URL=postgres://app_user:CHANGE_ME@localhost:5432/postgres

# Owner/superuser connection used ONLY by scripts/migrate.mjs and
# scripts/seed.mjs (npm run db:migrate / db:seed). Never used at request time.
DATABASE_ADMIN_URL=postgres://postgres:CHANGE_ME@localhost:5432/postgres

# --- Clerk (auth) ----------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# --- Slack -------------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_OAUTH_REDIRECT_URI=http://localhost:3000/api/slack/oauth/callback
# Random 32+ char secret for signing OAuth `state` (HMAC), e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SLACK_OAUTH_STATE_SECRET=
# Base64-encoded 32-byte AES-256-GCM key for encrypting Slack bot tokens at rest:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SLACK_TOKEN_ENCRYPTION_KEY=

# --- Stripe (billing, week 3) ----------------------------------------------
STRIPE_SECRET_KEY=
# From the Stripe CLI (`stripe listen --print-secret`) for local dev, or the
# webhook endpoint's signing secret in the Stripe Dashboard for deployed envs.
STRIPE_WEBHOOK_SECRET=
# Price ID for the paid 'readiness_review' tier subscription.
STRIPE_READINESS_REVIEW_PRICE_ID=
# Base URL used to build Stripe Checkout success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Claude API (AI readiness review, week 3) -------------------------------
ANTHROPIC_API_KEY=

# --- Supabase Storage (evidence uploads) ------------------------------------
# Service-role key is server-side only, never exposed to the browser. It's
# used only to mint short-lived signed upload/download URLs -- file bytes
# never pass through our Next.js server. Run `npm run storage:setup-bucket`
# once against a real project to create/configure the private bucket
# (25MB limit, restricted MIME types -- see scripts/setup-evidence-bucket.mjs).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVIDENCE_BUCKET=evidence

# --- Test database (tests/rls-pooling.test.ts only) -------------------------
# Point these at a local/disposable Postgres, never a shared or prod DB.
TEST_ADMIN_DATABASE_URL=
TEST_DATABASE_URL=
